# Copy to .env and fill in values before running locally or deploying

# ── Core ──────────────────────────────────────────────────────────────────────
# Set to "false" for production to make real LLM / screening calls
# Set to "true" for local dev to avoid API costs (all responses are canned)
MOCK=true

# ── Database ──────────────────────────────────────────────────────────────────
# Neon (production) or local Postgres (dev)
# Example Neon: postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://fund_ei:fund_ei_dev@db:5432/fund_ei

# ── AI APIs ──────────────────────────────────────────────────────────────────
# Required when MOCK=false — used for Text-to-SQL (Haiku) and Copilot (Sonnet)
ANTHROPIC_API_KEY=sk-ant-...

# Optional — OpenSanctions free tier works without a key; key removes rate limits
OPENSANCTIONS_API_KEY=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of additional allowed origins (set to your Vercel URL in prod)
# Example: https://your-app.vercel.app,https://custom-domain.com
ALLOWED_ORIGINS=

# ── Cost guard ────────────────────────────────────────────────────────────────
# Hard per-run budget cap in USD (default $0.50)
BUDGET_CAP_USD=0.50
